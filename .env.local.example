# ─── PokéTCG API ─────────────────────────────────────────────
# Inscription gratuite sur https://pokemontcg.io
# Sans clé : 100 req/10min | Avec clé : 20 000 req/jour
POKEMON_TCG_API_KEY=

# ─── PokeTrace (prix agrégés TCGPlayer + eBay + Cardmarket) ──
# Plan gratuit : 250 req/jour → https://poketrace.com/developers
POKETRACE_API_KEY=

# ─── PokemonPriceTracker (historique + données JP) ────────────
# Plan gratuit : 100 crédits/jour → https://pokemonpricetracker.com/api
PPT_API_KEY=

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

